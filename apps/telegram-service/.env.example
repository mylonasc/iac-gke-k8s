APP_ENV=dev
DATABASE_URL=sqlite:///./data/telegram_gateway.db
GATEWAY_SECRET_MASTER_KEY=

# Local admin UI login (not Dex)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-now

# Runtime JWT validation against existing Dex issuer
DEX_JWKS_URL=https://dex.example.local/keys
DEX_ISSUERS=https://dex.example.local
DEX_AUDIENCE=telegram-gateway
DEX_EMAIL_ALLOWLIST=
DEX_REQUIRED_GROUP=

# Telegram user login flow (MTProto)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional Telegram webhook verification
WEBHOOK_SHARED_SECRET=
