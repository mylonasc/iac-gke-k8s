{
  "name": "sandboxed-react-agent-frontend",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test -c playwright.ui.config.js",
    "test:e2e:terminal:compose": "playwright test --config=playwright.config.js e2e/terminal-compose.spec.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.10.0",
    "@assistant-ui/react": "0.12.16",
    "katex": "0.16.22",
    "lucide-react": "^1.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "9.0.3",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "xterm": "5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@testing-library/jest-dom": "6.7.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "jsdom": "26.1.0",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  }
}
