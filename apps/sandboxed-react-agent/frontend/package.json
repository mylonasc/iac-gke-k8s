    "react": "19.2.0",
    "react-dom": "19.2.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.53.2",
    "@testing-library/jest-dom": "6.7.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "jsdom": "26.1.0",
    "vite": "7.3.1",
