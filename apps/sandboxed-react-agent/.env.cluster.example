# Cluster-connected mode: tools run via the Agent Sandbox router in GKE.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_CALLS_PER_TURN=4

SANDBOX_MODE=cluster
# Use a reachable router URL from your machine, e.g. via port-forward:
# kubectl -n alt-default port-forward svc/sandbox-router-svc 18080:8080
SANDBOX_API_URL=http://host.docker.internal:18080
SANDBOX_TEMPLATE_NAME=python-runtime-template-small
SANDBOX_NAMESPACE=alt-default
SANDBOX_SERVER_PORT=8888
SANDBOX_MAX_OUTPUT_CHARS=6000
SANDBOX_EXECUTION_MODEL=session
SANDBOX_SESSION_IDLE_TTL_SECONDS=1800

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_COMMAND_PREVIEW_CHARS=200
TRACING_ENABLED=0
TRACING_SAMPLE_RATIO=0.1
OTEL_SERVICE_NAME=sandboxed-react-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# Identity (recommended: AUTH_ENABLED=1 with OIDC)
AUTH_ENABLED=0
ANON_IDENTITY_ENABLED=1
ANON_IDENTITY_SECRET=change-me-cluster-anon-secret

# Admin ops endpoints (/api/admin/ops/*)
OPS_ADMIN_ALLOW_ALL_AUTHENTICATED=1
OPS_ADMIN_EMAIL_ALLOWLIST=
OPS_ADMIN_GROUP_ALLOWLIST=
OPS_ADMIN_USER_ID_ALLOWLIST=
