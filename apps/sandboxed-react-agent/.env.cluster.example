# Cluster-connected mode: tools run via the Agent Sandbox router in GKE.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_CALLS_PER_TURN=4

SANDBOX_MODE=cluster
# Use a reachable router URL from your machine, e.g. via port-forward:
# kubectl -n alt-default port-forward svc/sandbox-router-svc 18080:8080
SANDBOX_API_URL=http://host.docker.internal:18080
SANDBOX_TEMPLATE_NAME=python-runtime-template
SANDBOX_NAMESPACE=alt-default
SANDBOX_SERVER_PORT=8888
SANDBOX_MAX_OUTPUT_CHARS=6000
