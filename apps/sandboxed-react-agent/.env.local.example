# Local-only mode: tools run inside the backend container.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_CALLS_PER_TURN=4

SANDBOX_MODE=local
SANDBOX_LOCAL_TIMEOUT_SECONDS=20
SANDBOX_MAX_OUTPUT_CHARS=6000
SANDBOX_EXECUTION_MODEL=session
SANDBOX_SESSION_IDLE_TTL_SECONDS=1800

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_COMMAND_PREVIEW_CHARS=200
TRACING_ENABLED=0
TRACING_SAMPLE_RATIO=0.1
OTEL_SERVICE_NAME=sandboxed-react-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# Identity (use OIDC in shared/prod environments)
AUTH_ENABLED=0
ANON_IDENTITY_ENABLED=1
ANON_IDENTITY_SECRET=change-me-local-anon-secret

# Admin ops endpoints (/api/admin/ops/*)
OPS_ADMIN_ALLOW_ALL_AUTHENTICATED=1
OPS_ADMIN_EMAIL_ALLOWLIST=
OPS_ADMIN_GROUP_ALLOWLIST=
OPS_ADMIN_USER_ID_ALLOWLIST=
