# Local-only mode: tools run inside the backend container.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_CALLS_PER_TURN=4

SANDBOX_MODE=local
SANDBOX_LOCAL_TIMEOUT_SECONDS=20
SANDBOX_MAX_OUTPUT_CHARS=6000
SANDBOX_EXECUTION_MODEL=session
SANDBOX_SESSION_IDLE_TTL_SECONDS=1800
SANDBOX_PERSISTENT_AUTO_FALLBACK_ENABLED=1
SANDBOX_LEASE_JANITOR_ENABLED=1
SANDBOX_LEASE_JANITOR_INTERVAL_SECONDS=45

# Optional: persistent workspace base template flavors.
# First value is the primary workspace base template.
SANDBOX_WORKSPACE_BASE_TEMPLATE_NAMES=python-runtime-template-small,python-runtime-template,python-runtime-template-large

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_COMMAND_PREVIEW_CHARS=200
TRACING_ENABLED=0
TRACING_SAMPLE_RATIO=0.1
OTEL_SERVICE_NAME=sandboxed-react-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# Identity (use OIDC in shared/prod environments)
# For local testing, keep AUTH_ENABLED=0 and ANON_IDENTITY_ENABLED=1
AUTH_ENABLED=0
ANON_IDENTITY_ENABLED=1
ANON_IDENTITY_SECRET=change-me-local-anon-secret

# Optional authz policy control plane integration
AUTHZ_POLICY_PATH=/app/data/authz-policy.yaml
AUTHZ_POLICY_URL=
AUTHZ_REFRESH_INTERVAL_SECONDS=30
AUTHZ_REMOTE_TIMEOUT_SECONDS=3

# Admin ops endpoints (/api/admin/ops/*)
OPS_ADMIN_ALLOW_ALL_AUTHENTICATED=1
OPS_ADMIN_EMAIL_ALLOWLIST=
OPS_ADMIN_GROUP_ALLOWLIST=
OPS_ADMIN_USER_ID_ALLOWLIST=
